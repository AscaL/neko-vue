{
  "name": "neko-vue",
  "version": "0.1.0",
  "description": "Vue 3 desktop pet — typed runtime, composable, and NekoPet component.",
  "keywords": [
    "composable",
    "desktop-pet",
    "neko",
    "neko-vue",
    "nekojs",
    "vue",
    "vue3"
  ],
  "homepage": "https://github.com/AscaL/neko-vue#readme",
  "bugs": {
    "url": "https://github.com/AscaL/neko-vue/issues"
  },
  "license": "MIT",
  "author": "AscaL (https://github.com/AscaL)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AscaL/neko-vue.git"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./types": {
      "types": "./dist/types.d.mts",
      "import": "./dist/types.mjs",
      "default": "./dist/types.mjs"
    },
    "./placement": {
      "types": "./dist/placement.d.mts",
      "import": "./dist/placement.mjs",
      "default": "./dist/placement.mjs"
    },
    "./runtime": {
      "types": "./dist/runtime.d.mts",
      "import": "./dist/runtime.mjs",
      "default": "./dist/runtime.mjs"
    },
    "./vue": {
      "types": "./dist/vue.d.mts",
      "import": "./dist/vue.mjs",
      "default": "./dist/vue.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "playground:dev": "bun run --cwd playground dev",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260328.1",
    "@vue/test-utils": "^2.4.6",
    "bumpp": "^11.0.1",
    "happy-dom": "^20.8.9",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.14",
    "vue": "^3.5.32"
  },
  "peerDependencies": {
    "vue": "^3.4.0 || ^3.5.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": false
    }
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "engines": {
    "node": "^18.18.0 || >=20.0.0"
  },
  "packageManager": "bun@1.3.11"
}
