{
  "name": "neko-vue",
  "version": "0.1.5",
  "description": "Vue 3 library for a viewport-fixed Neko-style desktop pet: NekoPet component, useNeko composable, loadNekoRuntime, and TypeScript types. Ships the pet engine inside the package (dynamic import). Peer: vue ^3.4 || ^3.5.",
  "keywords": [
    "animation",
    "component",
    "composable",
    "createNeko",
    "desktop-pet",
    "neko",
    "neko-cat",
    "neko-vue",
    "nekojs",
    "sprite",
    "typescript",
    "viewport",
    "vue",
    "vue-component",
    "vue3",
    "vuejs"
  ],
  "homepage": "https://github.com/AscaL/neko-vue#readme",
  "bugs": {
    "url": "https://github.com/AscaL/neko-vue/issues"
  },
  "license": "MIT",
  "author": {
    "name": "AscaL",
    "url": "https://github.com/AscaL"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AscaL/neko-vue.git"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./types": {
      "types": "./dist/types.d.mts",
      "import": "./dist/types.mjs",
      "default": "./dist/types.mjs"
    },
    "./placement": {
      "types": "./dist/placement.d.mts",
      "import": "./dist/placement.mjs",
      "default": "./dist/placement.mjs"
    },
    "./runtime": {
      "types": "./dist/runtime.d.mts",
      "import": "./dist/runtime.mjs",
      "default": "./dist/runtime.mjs"
    },
    "./vue": {
      "types": "./dist/vue.d.mts",
      "import": "./dist/vue.mjs",
      "default": "./dist/vue.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "playground:dev": "bun run --cwd playground dev",
    "test": "vp test",
    "check": "vp check src tests vite.config.ts",
    "check:playground": "vp check playground/src playground/vite.config.ts",
    "check:all": "vp check src tests vite.config.ts && vp check playground/src playground/vite.config.ts",
    "prepublishOnly": "vp run build",
    "release": "commit-and-tag-version"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.5.2",
    "@typescript/native-preview": "7.0.0-dev.20260404.1",
    "@vue/test-utils": "^2.4.6",
    "bumpp": "^11.0.1",
    "commit-and-tag-version": "^12.7.1",
    "happy-dom": "^20.8.9",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.15",
    "vue": "^3.5.32"
  },
  "peerDependencies": {
    "vue": "^3.4.0 || ^3.5.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": false
    }
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "bun@1.3.11"
}
